{
  "standard": "GHRAB-QA-1.0.2",
  "appId": "essay-evaluator",
  "appName": "Hodnotitel maturitních slohů",
  "appVersion": "1.5.1",
  "entryPoint": "dist/index.html",
  "serveRoot": "dist",
  "buildRoot": "dist",
  "installCommand": "npm ci --no-fund",
  "buildCommand": "npm run build",
  "testCommand": "npm test",
  "headlessCommand": "",
  "auditCommand": "npm audit --audit-level=high",
  "features": {
    "pwa": true,
    "ai": true,
    "centralAccessGuard": true,
    "fileExport": true,
    "studentRuntime": false,
    "teacherRuntime": true,
    "localStorage": true,
    "serviceWorker": true
  },
  "requiredViewports": [
    {
      "width": 360,
      "height": 800
    },
    {
      "width": 412,
      "height": 915
    },
    {
      "width": 768,
      "height": 1024
    },
    {
      "width": 1366,
      "height": 768
    },
    {
      "width": 1920,
      "height": 1080
    }
  ],
  "versionChecks": [
    {
      "file": "CHANGELOG.md",
      "regex": "## ([0-9.]+)",
      "expected": "1.5.1"
    },
    {
      "file": "dist/app.js",
      "regex": "version:'([0-9.]+)'",
      "expected": "1.5.1"
    },
    {
      "file": "dist/sw.js",
      "regex": "APP_VERSION='([0-9.]+)'",
      "expected": "1.5.1"
    },
    {
      "file": "dist/studio-manifest.json",
      "regex": "\"version\"\\s*:\\s*\"([0-9.]+)\"",
      "expected": "1.5.1"
    }
  ],
  "pwaTargets": [
    {
      "id": "hodnotitel",
      "root": "dist",
      "manifest": "manifest.webmanifest",
      "serviceWorker": "sw.js",
      "cachePrefix": "hodnotitel-"
    }
  ],
  "security": {
    "allowedEmails": [
      "balaz@ghrabuvka.cz"
    ],
    "requiresCsvFormulaProtection": false,
    "validator": "qa/security-validator.mjs",
    "auditDerivedControls": [
      "manual-ai-schema-roundtrip",
      "technical-marker-exclusion",
      "non-recycled-pseudonymous-ids",
      "attachment-text-gate",
      "raw-ai-response-minimization",
      "batch-key-fail-closed",
      "truncated-ai-response-handling",
      "prompt-injection-boundary",
      "persistent-api-key-confirmation"
    ]
  },
  "compatibility": {
    "runtimeSourceRoots": [
      "src"
    ],
    "disallowRegexLookbehind": true
  }
}
